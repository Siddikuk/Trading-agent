# ─── REQUIRED ────────────────────────────────────────────────────────────────

# Anthropic Claude API key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Neon PostgreSQL connection string — same DATABASE_URL as your Next.js app
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── OPTIONAL (defaults shown) ───────────────────────────────────────────────

# MT5 bridge URL — agent runs on same VPS so localhost works
MT5_BRIDGE_URL=http://localhost:8080

# How often the agent scans (minutes)
AGENT_SCAN_INTERVAL_MINUTES=15

# Maximum open positions at one time
AGENT_MAX_POSITIONS=5

# Maximum lot size per trade (cent account default: 0.10)
AGENT_MAX_LOT=0.10

# Log verbosity: DEBUG | INFO | WARNING | ERROR
AGENT_LOG_LEVEL=INFO

# ─── MULTI-TIMEFRAME ─────────────────────────────────────────────────────────

# Timeframes to analyse per symbol (comma-separated, top-down order)
AGENT_TIMEFRAMES=M15,H1,H4,D1

# Minimum number of timeframes that must agree to run Claude (saves API cost)
AGENT_MIN_TF_CONFLUENCE=2

# Lot multiplier when 3/4 timeframes agree
AGENT_LOT_SCALE_3TF=1.5

# Lot multiplier when all 4 timeframes agree
AGENT_LOT_SCALE_4TF=2.0

# Maximum concurrent Claude API calls (avoid rate limiting)
AGENT_MAX_CONCURRENT_CLAUDE=2
