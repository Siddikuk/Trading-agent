generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Trade {
  id          String   @id @default(cuid())
  symbol      String
  direction   String
  lotSize     Float
  entryPrice  Float
  stopLoss    Float?
  takeProfit  Float?
  exitPrice   Float?
  pnl         Float?
  status      String   @default("OPEN")
  signalId    String?
  strategy    String?
  openTime    DateTime @default(now())
  closeTime   DateTime?
  notes       String?
}

model Signal {
  id          String   @id @default(cuid())
  symbol      String
  direction   String
  confidence  Float
  entryPrice  Float
  stopLoss    Float
  takeProfit  Float
  strategy    String
  timeframe   String
  indicators  String
  executed    Boolean  @default(false)
  tradeId     String?
  createdAt   DateTime @default(now())
  expiresAt   DateTime?
}

model AgentState {
  id              String @id @default("main")
  isRunning       Boolean @default(false)
  autoTrade       Boolean @default(false)
  balance         Float   @default(1000)
  currency        String  @default("USD")
  maxRiskPercent  Float   @default(2)
  maxDrawdownPercent Float @default(10)
  dailyRiskLimit  Float   @default(5)
  strategies      String  @default("RSI,MACD,Bollinger")
  watchSymbols    String  @default("EURUSD=X,GBPUSD=X,USDJPY=X,XAUUSD=X,BTCUSD=X")
  timeframe       String  @default("1h")
  mt5Connected    Boolean @default(false)
  lastScanAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PriceAlert {
  id        String   @id @default(cuid())
  symbol    String
  condition String
  price     Float
  isActive  Boolean  @default(true)
  triggered Boolean  @default(false)
  createdAt DateTime @default(now())
  triggeredAt DateTime?
}

model WatchlistGroup {
  id        String @id @default(cuid())
  name      String @unique
  symbols   String
  isBuiltIn Boolean @default(false)
  createdAt DateTime @default(now())
}
