# Local SQLite database — no cloud setup needed
DATABASE_URL="file:./dev.db"

# ── FOR VERCEL (production) ───────────────────────────────────────────────────
# 1. Go to neon.tech → create free project → copy the connection string
# 2. Add these in Vercel dashboard → Settings → Environment Variables:
#    POSTGRES_PRISMA_URL = postgresql://user:pass@host/db?sslmode=require
#    DATABASE_URL        = postgresql://user:pass@host/db?sslmode=require
# Then change prisma/schema.prisma provider back to "postgresql"
# ─────────────────────────────────────────────────────────────────────────────
